{
  "name": "ecommerce",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:storefront": "turbo -F storefront dev",
    "dev:store": "turbo -F store dev",
    "dev:medusa": "turbo -F medusa dev",
    "bump-deps": "turbo bump-deps",
    "db:start": "docker compose -f docker/docker-compose.yml up -d",
    "db:stop": "docker compose -f docker/docker-compose.yml stop",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:setup": "bash docker/db-setup.sh",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "clean:lockfile": "rm -f pnpm-lock.yaml && pnpm install",
    "clean:node_modules": "rm -rf node_modules && find . -name 'node_modules' -type d -prune -exec rm -rf {} +"
  },
  "dependencies": {
    "@ecommerce/env": "workspace:*",
    "axios": "^1.18.0",
    "dotenv": "catalog:",
    "pdfmake": "^0.3.11",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ecommerce/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.9.18",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "overrides": {
    "undici": "5.20.0"
  },
  "packageManager": "pnpm@11.8.0"
}
